<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.board.springboard.model.mapper.BoardImageMapper">

    <select id="이미지목록" resultType="com.board.springboard.model.dto.BoardImage">
        SELECT *
        FROM board_images
        WHERE board_no = #{board_no}
    </select>

    <!-- 이미지 한 장 저장 -->
    <insert id="이미지저장" parameterType="com.board.springboard.model.dto.BoardImage">
        INSERT INTO board_images (board_no, img_path)
        VALUES (#{board_no}, #{img_path})
    </insert>

    <!-- 특정 게시물 이미지 전체 삭제 -->
    <delete id="이미지전체삭제" parameterType="int">
        DELETE FROM board_images
        WHERE board_no = #{board_no}
    </delete>
</mapper>